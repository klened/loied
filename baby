  const firstMeet = s.order === 1 ? 200 : 300;
  benefits.push({ src: 'gov', icon: '🎁', title: '첫만남이용권', amount: firstMeet, due: '출생 후 1년 이내', desc: '국민행복카드 바우처. 유흥·사행업종 제외 자유 사용', byAge: { age0: firstMeet, age1: 0, age2_6: 0, age7: 0 } });
  benefits.push({ src: 'gov', icon: '💰', title: '부모급여 (0세)', amount: 1200, due: '출생신고 시 자동', desc: '만 0세(0~11개월) 월 100만원 ×12개월. 어린이집 이용 시 보육료 차감', byAge: { age0: 1200, age1: 0, age2_6: 0, age7: 0 } });
  benefits.push({ src: 'gov', icon: '💰', title: '부모급여 (1세)', amount: 600, due: '자동 전환', desc: '만 1세(12~23개월) 월 50만원 ×12개월', byAge: { age0: 0, age1: 600, age2_6: 0, age7: 0 } });
  const a0 = 120, a1 = 120, a26 = 600, a7 = 120;
  benefits.push({ src: 'gov', icon: '👶', title: '아동수당', amount: a0 + a1 + a26 + a7, due: '매월 25일', desc: '만 0~8세 매월 10만원 (2030년까지 단계적 만 13세 확대)', byAge: { age0: a0, age1: a1, age2_6: a26, age7: a7 } });
  benefits.push({ src: 'gov', icon: '🏠', title: '가정양육수당', amount: 600, due: '미이용 기간만', desc: '24~83개월 가정양육 시 월 10만원 (어린이집·유치원 미이용 조건)', byAge: { age0: 0, age1: 0, age2_6: 600, age7: 0 } });
  let preg = s.multi === 1 ? 100 : 140;
  if (s.remote) preg += 20;
  benefits.push({ src: 'gov', icon: '🏥', title: '임신·출산 진료비', amount: preg, due: '임신확인 직후', desc: '국민행복카드. 단태아 100만원 / 다태아 140만원' + (s.remote ? ' + 분만취약지 20만원' : ''), byAge: { age0: preg, age1: 0, age2_6: 0, age7: 0 } });
  if (s.work !== 'none' && s.wage > 0) {
    const w = s.wage;
    const m1 = Math.min(w, 250) * 3;
    const m2 = Math.min(w, 200) * 3;
    const m3 = Math.min(w * 0.8, 160) * 6;
    const pay = Math.round(m1 + m2 + m3);
    const couple = s.work === 'both' ? 2 : 1;
    const total = pay * couple;
    benefits.push({ src: 'gov', icon: '👨‍👩‍👧', title: '육아휴직급여' + (couple === 2 ? ' (부부합산)' : ''), amount: total, due: '휴직 후 1개월 내 신청', desc: '1~3개월 100%(상한 250만) · 4~6개월 100%(상한 200만) · 7~12개월 80%(상한 160만)', byAge: { age0: total, age1: 0, age2_6: 0, age7: 0 } });
  }
  if (s.work !== 'none') {
    const pp = s.multi >= 2 ? 800 : 600;
    benefits.push({ src: 'gov', icon: '🤱', title: '출산전후휴가 급여', amount: pp, due: '출산 후 1년 이내', desc: '90일(다태아 120일) 통상임금 100% (상한 적용)', byAge: { age0: pp, age1: 0, age2_6: 0, age7: 0 } });
  }
  if (s.noHouse && s.income > 0 && s.income <= 25000) {
    benefits.push({ src: 'gov', icon: '🏦', title: '신생아 특례 대출 (이자절감 추정)', amount: 1500, due: '출산 후 2년 이내', desc: '특례금리 1.3~3.3% 5년 적용 · 추가 출산 시 5년씩 연장 (이자 절감액 추정 1,500만원)', byAge: { age0: 0, age1: 1500, age2_6: 0, age7: 0 } });
  }
  if (s.region1 && REGIONS[s.region1]) {
    const m = REGIONS[s.region1].metro;
    const car = m.car[s.order - 1] || m.car[3];
    const birth = m.birth[s.order - 1] || m.birth[3];
    const sum = car + birth;
    if (sum > 0) {
      benefits.push({ src: 'metro', icon: '🏙', title: m.name + ' 출산·산후 지원', amount: sum, due: '지자체별 상이', desc: m.note, byAge: { age0: sum, age1: 0, age2_6: 0, age7: 0 } });
    }
  }
  if (s.region1 && s.region2 && REGIONS[s.region1].sub[s.region2]) {
    const local = REGIONS[s.region1].sub[s.region2];
    const localAmt = local[s.order - 1] || local[3];
    if (localAmt > 0) {
      benefits.push({ src: 'local', icon: '🎈', title: s.region2 + ' 출산장려금', amount: localAmt, due: '출산 후 1년 이내 (지자체 상이)', desc: '주민센터 신청. 분할 지급 또는 일시금 (지자체별 상이)', byAge: { age0: Math.round(localAmt * 0.5), age1: Math.round(localAmt * 0.3), age2_6: Math.round(localAmt * 0.2), age7: 0 } });
    }
  }
  return benefits;
}

function animateNumber(el, target) {
  const dur = 900, t0 = performance.now();
  function step(t) {
    const p = Math.min(1, (t - t0) / dur);
    const e = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(target * e).toLocaleString();
    if (p < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
function fmt(v) { return v > 0 ? v.toLocaleString() + '만' : '<span class="dash">–</span>'; }

function render() {
  const benefits = calc();
  let sumAll = 0, sumGov = 0, sumMetro = 0, sumLocal = 0;
  let age0 = 0, age1 = 0, age26 = 0, age7 = 0;
  benefits.forEach(b => {
    sumAll += b.amount;
    if (b.src === 'gov') sumGov += b.amount;
    if (b.src === 'metro') sumMetro += b.amount;
    if (b.src === 'local') sumLocal += b.amount;
    age0 += b.byAge.age0; age1 += b.byAge.age1; age26 += b.byAge.age2_6; age7 += b.byAge.age7;
  });
  animateNumber(document.getElementById('megaTotal'), sumAll);
  document.getElementById('byGov').textContent = sumGov.toLocaleString() + '만';
  document.getElementById('byMetro').textContent = sumMetro.toLocaleString() + '만';
  document.getElementById('byLocal').textContent = sumLocal.toLocaleString() + '만';
  const tb = document.getElementById('timelineBody');
  tb.innerHTML = benefits.map(b =>
    '<tr><td>' + b.icon + ' ' + b.title + '</td>' +
    '<td>' + fmt(b.byAge.age0) + '</td>' +
    '<td>' + fmt(b.byAge.age1) + '</td>' +
    '<td>' + fmt(b.byAge.age2_6) + '</td>' +
    '<td>' + fmt(b.byAge.age7) + '</td>' +
    '<td><b>' + b.amount.toLocaleString() + '만</b></td></tr>'
  ).join('') +
    '<tr class="sum"><td>합계</td>' +
    '<td>' + fmt(age0) + '</td><td>' + fmt(age1) + '</td>' +
    '<td>' + fmt(age26) + '</td><td>' + fmt(age7) + '</td>' +
    '<td>' + sumAll.toLocaleString() + '만</td></tr>';
  const srcLabel = { gov: '정부 지원', metro: '광역(시·도)', local: '기초(시·군·구)' };
  document.getElementById('benefitList').innerHTML = benefits.map(b =>
    '<div class="benefit-card reveal">' +
      '<div class="benefit-icon ' + b.src + '">' + b.icon + '</div>' +
      '<div class="benefit-body">' +
        '<div class="benefit-head">' +
          '<div class="benefit-title">' + b.title + '</div>' +
          '<div class="benefit-amount">' + b.amount.toLocaleString() + '만원</div>' +
        '</div>' +
        '<div class="benefit-tags">' +
          '<span class="src-tag ' + b.src + '">' + srcLabel[b.src] + '</span>' +
          '<span class="due-tag">🗓 ' + b.due + '</span>' +
        '</div>' +
        '<div class="benefit-desc">' + b.desc + '</div>' +
      '</div>' +
    '</div>'
  ).join('');
  document.getElementById('resultCount').textContent = '총 ' + benefits.length + '개 혜택 합산';
  setTimeout(() => {
    document.querySelectorAll('#benefitList .benefit-card').forEach(el => io.observe(el));
  }, 50);
}

document.getElementById('filterForm').addEventListener('submit', e => {
  e.preventDefault();
  if (!state.region1) { alert('광역시·도를 선택해주세요.'); sel1.focus(); return; }
  const loading = document.getElementById('loading');
  const results = document.getElementById('results');
  results.classList.remove('show');
  loading.classList.add('show');
  loading.scrollIntoView({ behavior: 'smooth', block: 'center' });
  setTimeout(() => {
    loading.classList.remove('show');
    results.classList.add('show');
    render();
    setTimeout(() => results.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
  }, 700);
});

const progressBar = document.getElementById('readingProgress');
window.addEventListener('scroll', () => {
  const h = document.documentElement.scrollHeight - window.innerHeight;
  progressBar.style.width = (h > 0 ? window.scrollY / h * 100 : 0) + '%';
}, { passive: true });
const topBtn = document.getElementById('topBtn');
window.addEventListener('scroll', () => { topBtn.classList.toggle('show', window.scrollY > 400); }, { passive: true });
topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
const themeRoot = document.documentElement;
const darkToggle = document.getElementById('darkToggle');
const initial = themeRoot.getAttribute('data-baby-theme') || 'light';
darkToggle.textContent = initial === 'dark' ? '☀️' : '🌙';
darkToggle.addEventListener('click', () => {
  const cur = themeRoot.getAttribute('data-baby-theme') || 'light';
  const next = cur === 'dark' ? 'light' : 'dark';
  themeRoot.setAttribute('data-baby-theme', next);
  localStorage.setItem('baby-theme', next);
  darkToggle.textContent = next === 'dark' ? '☀️' : '🌙';
});
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.form-card, .faq-item, .step-bar, .disclaimer, .mega-card, .timeline-card').forEach(el => { el.classList.add('reveal'); io.observe(el); });
function animateCounter(el, target, suffix, dur) {
  const t0 = performance.now();
  function step(t) {
    const p = Math.min((t - t0) / dur, 1);
    const e = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.floor(target * e) + suffix;
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = target + suffix;
  }
  requestAnimationFrame(step);
}
document.querySelectorAll('.hero-stat .num').forEach((el, i) => {
  const m = el.textContent.match(/^(\d+)(.*)$/);
  if (m) {
    const target = parseInt(m[1]);
    const suffix = m[2];
    el.textContent = '0' + suffix;
    setTimeout(() => animateCounter(el, target, suffix, 1200), 200 + i * 100);
  }
});
</script>
</body>
</html>

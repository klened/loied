    chip.addEventListener('click', function() {
      const input = this.querySelector('input');
      if (!input) return;
      if (input.type === 'radio') {
        grid.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
        this.classList.add('active');
        input.checked = true;
        const key = grid.dataset.key;
        if (key) state[key] = (key === 'order' || key === 'multi') ? parseInt(input.value) : input.value;
        if (key === 'order') updateRegionPreview();
      }
    });
  });
});

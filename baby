  const display = m < 12 ? '생후 ' + m + '개월' : '만 ' + Math.floor(m / 12) + '세 ' + (m % 12) + '개월';
  document.getElementById('ageLabel').textContent = display + ' · ' + bracket;
});

function formatKoreanMoney(manwon) {
  if (!manwon || manwon <= 0) return '';
  const eok = Math.floor(manwon / 10000);
  const remain = manwon % 10000;
  const parts = [];
  if (eok > 0) parts.push(eok.toLocaleString() + '억');
  if (remain > 0) {
    if (remain % 1000 === 0 && remain >= 1000) parts.push((remain / 1000) + '천만');
    else parts.push(remain.toLocaleString() + '만');
  }
  return parts.join(' ') + '원';
}
function unformat(v) { return parseInt(String(v).replace(/[^\d]/g, '')) || 0; }
function setupAmountInput(inputId, previewId, stateKey) {
  const input = document.getElementById(inputId);
  const preview = document.getElementById(previewId);
  input.addEventListener('input', e => {
    const raw = unformat(e.target.value);
    e.target.value = raw ? raw.toLocaleString() : '';
    state[stateKey] = raw;
    const k = formatKoreanMoney(raw);
    if (k) {
      preview.innerHTML = '입력 금액 <span class="arrow">→</span> <strong>' + k + '</strong>';
      preview.classList.add('visible');
    } else preview.classList.remove('visible');
  });
}

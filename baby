function updateRegionPreview() {
  const box = document.getElementById('regionPreview');
  if (!state.region1 || !state.region2) { box.classList.remove('visible'); return; }
  const r = REGIONS[state.region1];
  const local = r.sub[state.region2];
  const amt = local[state.order - 1] || local[3];
  box.classList.add('visible');
  box.innerHTML = '📍 <b>' + state.region1 + ' ' + state.region2 + '</b>' +
    ' · ' + (state.order === 3 ? '셋째 이상' : '순위 ' + state.order) +
    ' 기준 출산장려금 <b>약 ' + amt.toLocaleString() + '만원</b>' +
    (r.metro.note ? '<span class="sub">광역: ' + r.metro.note + '</span>' : '');
}

